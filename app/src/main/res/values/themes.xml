<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.FlexIT" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Charpente : bleu nuit -->
        <item name="colorPrimary">@color/flexit_navy_500</item>
        <item name="colorPrimaryVariant">@color/flexit_navy_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Accent : orange-rouge -->
        <item name="colorSecondary">@color/flexit_red_500</item>
        <item name="colorSecondaryVariant">@color/flexit_red_700</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <style name="Theme.FlexIT.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.FlexIT.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.FlexIT.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>
